# Fonte de dados: mock | api | sheet | database
WAR_ROOM_SOURCE=mock
WAR_ROOM_SESSION_SECRET=troque-este-segredo-em-producao

# ---------------------------
# API externa (WAR_ROOM_SOURCE=api)
# ---------------------------
WAR_ROOM_API_URL=https://sua-api.com/war-room
WAR_ROOM_API_TOKEN=

# ---------------------------
# Google Sheets (WAR_ROOM_SOURCE=sheet)
# ---------------------------
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_RANGE_ADS_METRICS=ads_metrics!A1:C10
GOOGLE_SHEETS_RANGE_CREATIVES=creatives!A1:E200
GOOGLE_SHEETS_RANGE_COPY_ANGLES=copy_angles!A1:A200
GOOGLE_SHEETS_RANGE_HOOKS_BACKLOG=hooks_backlog!A1:A200
GOOGLE_SHEETS_RANGE_PRODUCTION_FLOW=production_flow!A1:B200
GOOGLE_SHEETS_RANGE_TECH_METRICS=tech_metrics!A1:F20
GOOGLE_SHEETS_RANGE_FINANCE_METRICS=finance_metrics!A1:C20

# ---------------------------
# PostgreSQL (WAR_ROOM_SOURCE=database)
# ---------------------------
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
DATABASE_SSL=false
# Persistencia operacional: file | database
# Em "database", jobs/eventos/incidentes usam Postgres com lock distribuido.
WAR_ROOM_OPS_PERSISTENCE_MODE=file

# ---------------------------
# Notificacoes externas (opcional)
# ---------------------------
SLACK_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=

# ---------------------------
# Webhook de integracao (Appmax, Kiwify, Yampi, Utmify)
# ---------------------------
WAR_ROOM_WEBHOOK_API_KEY=troque-por-uma-chave-forte

# ---------------------------
# Pull sync opcional das APIs de integracao
# (se configuradas, o backend tenta sincronizar no carregamento)
# ---------------------------
UTMIFY_API_URL=
UTMIFY_API_TOKEN=
APPMAX_API_URL=
APPMAX_API_TOKEN=
KIWIFY_API_URL=
KIWIFY_API_TOKEN=
YAMPI_API_URL=
YAMPI_API_TOKEN=
WAR_ROOM_TAX_RATE_PCT=8.5
WAR_ROOM_FIXED_COSTS=0
WAR_ROOM_META_REPORTED_PURCHASES=
WAR_ROOM_VAULT_DOMAINS=checkout-principal.com,reserva-warroom.com
GOOGLE_SAFE_BROWSING_API_KEY=
META_GRAPH_ACCESS_TOKEN=
WAR_ROOM_PUSH_ALERT_WEBHOOK=
WAR_ROOM_WEBHOOK_SYNC_MODE=false

# Segredos HMAC opcionais por provedor (webhooks)
UTMIFY_WEBHOOK_SECRET=
APPMAX_WEBHOOK_SECRET=
KIWIFY_WEBHOOK_SECRET=
YAMPI_WEBHOOK_SECRET=
